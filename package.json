{
  "name": "exchange-terminal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "node server.cjs",
    "dev:full": "concurrently -k -n \"vite,server\" -c \"cyan,green\" \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
