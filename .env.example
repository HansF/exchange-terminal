# Gemini powers StencilCam. Leave empty if you only use the non-AI tools.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# printd thermal print service (https://github.com/HansF/printd).
# PRINT_SERVICE_KEY must match printd's PRINTD_API_KEY when auth is enabled.
PRINT_SERVICE_URL=http://localhost:8080
PRINT_SERVICE_KEY=changeme
